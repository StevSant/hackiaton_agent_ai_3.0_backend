# ===== App =====
APP_ENV=dev                                   # dev | test | prod
APP_NAME=hackiaton-agent-ai-3-0-backend
LOG_LEVEL=INFO                                # DEBUG | INFO | WARNING | ERROR
DEBUG_ENABLED=true                            # gates the PATCH /claims/{id} demo fire-test

# ===== HTTP =====
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=["http://localhost:4200"]

# ===== Server (used by `uv run app`) =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true

# ===== Database (SQLAlchemy + asyncpg driver) =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fraudia
# Connection resilience for a remote pooler (e.g. Supabase): retry a fast-failing
# connect (transient DNS/TCP blip) this many times before returning a clean 503.
# A connect timeout is treated as "down" and not retried.
DB_CONNECT_MAX_RETRIES=3                      # extra attempts after the first (0 = no retry)
DB_CONNECT_RETRY_BACKOFF_S=0.25               # base backoff; grows exponentially per retry

# ===== LLM (OpenAI-only for the hackathon — locked 2026-05-26) =====
LLM_PROVIDER=openai                           # openai | fake (use 'fake' for offline dev/tests)
LLM_DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=                               # required when LLM_PROVIDER=openai
WHISPER_MODEL=whisper-1
TRANSCRIBE_MAX_BYTES=10485760                 # 10 MB
TRANSCRIBE_ALLOWED_MIME=["audio/webm","audio/mp4","audio/mpeg","audio/wav","audio/ogg","audio/x-m4a","audio/mp3"]

# ===== Embeddings =====
# Default: OpenAI text-embedding-3-small with dimensions=384 (matches the
# pgvector(384) schema). Switch to sentence_transformers for an offline
# fallback (uses paraphrase-multilingual-MiniLM-L12-v2 ~470 MB CPU model).
EMBEDDINGS_PROVIDER=openai                    # openai | sentence_transformers
EMBEDDINGS_MODEL=text-embedding-3-small       # or paraphrase-multilingual-MiniLM-L12-v2 for sentence_transformers
EMBEDDINGS_DIM=384
EMBEDDINGS_BATCH_SIZE=256                      # texts per embedding request during bulk re-index (<= provider cap)

# ===== Vector store (pgvector primary, in_memory fallback if pgvector blocks) =====
VECTOR_STORE=pgvector                         # pgvector | in_memory

# ===== ML / Anomaly model artifacts (paths read from this project root) =====
FRAUD_MODEL_PATH=data/models/fraud_lgbm.txt
ANOMALY_MODEL_PATH=data/models/anomaly_iforest.joblib

# ===== Rules =====
RULES_CONFIG_PATH=app/domain/rules/config.yaml
SIMILARITY_THRESHOLD_FS13=0.85                # FS-13 (narrativas similares) fires above this
SIMILARITY_DISPLAY_MIN=0.50                   # min cosine for a neighbour to show in the "Narrativas similares" panel

# ===== Vehicle identity (FS-15 — chassis/VIN decode) =====
# hybrid: real 17-char VINs → NHTSA vPIC, synthetic chassis → offline registry.
# registro: always use the offline deterministic registry (no network).
# nhtsa: always call NHTSA vPIC (real VINs only).
VEHICLE_DECODER_PROVIDER=hybrid               # hybrid | registro | nhtsa
NHTSA_VPIC_URL=https://vpic.nhtsa.dot.gov/api # NHTSA vPIC base URL (no API key needed)
VEHICLE_DECODER_TIMEOUT_S=8.0                 # per-request HTTP timeout for the NHTSA decode

# ===== Agent (ReAct loop + conversation memory) =====
MAX_REACT_STEPS=3                             # max tool-use iterations per turn
MAX_CONVERSATION_TURNS=8                      # how many prior HumanMessage exchanges to retain

# ===== Data =====
DATA_DIR=data
LOAD_DATASET_ON_STARTUP=true

# ===== Auth (V0 — local JWT, env-seeded users) =====
AUTH_ENABLED=true
JWT_SECRET=change-me-before-demo
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=480
# JSON array of {email, password (plaintext here), role, full_name}.
# Hashed with bcrypt at boot by EnvSeededUserRepo; hashes never persisted.
# .env.example ships placeholders; never commit real passwords.
AUTH_SEED_USERS=[{"email":"analista@demo.com","password":"replace-me-locally","role":"analista","full_name":"Analista Demo"},{"email":"antifraude@demo.com","password":"replace-me-locally","role":"antifraude","full_name":"Antifraude Demo"}]

# ===== Storage (Supabase Storage) — re-added per user request; overrides §11/§13 deferral; OPTIONAL =====
# Leave SUPABASE_URL unset to use the in-memory adapter (app boots without Supabase).
SUPABASE_URL=                                 # e.g. https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                    # service_role key from Project Settings → API; NEVER sent to the frontend
SUPABASE_STORAGE_BUCKET=siniestros-documentos # bucket must exist and have the RLS policy below
UPLOAD_MAX_BYTES=26214400                     # 25 MB
UPLOAD_ALLOWED_MIME=["application/pdf","image/jpeg","image/png","image/webp"]
