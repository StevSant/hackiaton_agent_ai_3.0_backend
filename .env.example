# ===== App =====
APP_ENV=dev                                   # dev | test | prod
APP_NAME=hackiaton-agent-ai-3-0-backend
LOG_LEVEL=INFO                                # DEBUG | INFO | WARNING | ERROR

# ===== HTTP =====
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=["http://localhost:4200"]

# ===== Database (SQLAlchemy + asyncpg driver) =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ===== Supabase =====
SUPABASE_URL=                                 # https://<project>.supabase.co
SUPABASE_ANON_KEY=                            # public anon key
SUPABASE_SERVICE_ROLE_KEY=                    # SERVER-ONLY — never expose to the browser
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=                            # https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# ===== LLM =====
LLM_PROVIDER=openai                           # openai | anthropic | local
LLM_DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== Embeddings =====
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536

# ===== Uploads =====
UPLOAD_MAX_BYTES=26214400                     # 25 MiB
UPLOAD_ALLOWED_MIME=["application/pdf","text/plain","text/markdown"]
